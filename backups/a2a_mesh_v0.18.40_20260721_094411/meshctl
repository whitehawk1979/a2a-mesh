#!/usr/bin/env bash
# meshctl — Helper for A2A Mesh systemd services
# Usage: meshctl {start|stop|restart|status|log|follow|enable|disable|list} [morzsa|runa|all]

set -euo pipefail

# Service name mapping
declare -A SVC_MAP=(
    [morzsa]="a2a-mesh.service"
    [runa]="a2a-mesh-runa.service"
)
NODES=("morzsa" "runa")

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${GREEN}[INFO]${NC} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*"; }

get_nodes() {
    local target="${1:-all}"
    if [[ "$target" == "all" ]]; then
        echo "${NODES[@]}"
    elif [[ " ${NODES[*]} " =~ " $target " ]]; then
        echo "$target"
    else
        error "Unknown node: $target (available: ${NODES[*]})"
        exit 1
    fi
}

svc_name() { echo "${SVC_MAP[$1]}"; }

cmd_start() {
    local target="${1:-all}"
    for node in $(get_nodes "$target"); do
        info "Starting $node..."
        systemctl --user start "$(svc_name "$node")"
    done
    sleep 1
    cmd_status "$target"
}

cmd_stop() {
    local target="${1:-all}"
    for node in $(get_nodes "$target"); do
        info "Stopping $node..."
        systemctl --user stop "$(svc_name "$node")"
    done
}

cmd_restart() {
    local target="${1:-all}"
    for node in $(get_nodes "$target"); do
        info "Restarting $node..."
        systemctl --user restart "$(svc_name "$node")"
    done
    sleep 1
    cmd_status "$target"
}

cmd_status() {
    local target="${1:-all}"
    for node in $(get_nodes "$target"); do
        local svc
        svc="$(svc_name "$node")"
        local state pid since
        state=$(systemctl --user is-active "$svc" 2>/dev/null || echo "unknown")
        
        if [[ "$state" == "active" ]]; then
            pid=$(systemctl --user show "$svc" -p MainPID --value 2>/dev/null || echo "-")
            since=$(systemctl --user show "$svc" -p ActiveEnterTimestamp --value 2>/dev/null || echo "-")
            echo -e "  ${GREEN}● $node${NC}  $state  PID=$pid  since $since"
        elif [[ "$state" == "failed" ]]; then
            echo -e "  ${RED}✗ $node${NC}  $state"
            echo -e "    Run: systemctl --user status $svc"
        else
            echo -e "  ${YELLOW}○ $node${NC}  $state"
        fi
    done
}

cmd_log() {
    local target="${1:-all}"
    local count="${2:-50}"
    if [[ "$target" == "all" ]]; then
        journalctl --user -t a2a-morzsa -t a2a-runa --no-pager -n "$count" -o cat
    else
        journalctl --user -t "a2a-$target" --no-pager -n "$count" -o cat
    fi
}

cmd_enable() {
    local target="${1:-all}"
    for node in $(get_nodes "$target"); do
        info "Enabling $node (auto-start on login)..."
        systemctl --user enable "$(svc_name "$node")"
    done
}

cmd_disable() {
    local target="${1:-all}"
    for node in $(get_nodes "$target"); do
        info "Disabling $node..."
        systemctl --user disable "$(svc_name "$node")"
    done
}

cmd_follow() {
    local target="${1:-all}"
    if [[ "$target" == "all" ]]; then
        journalctl --user -t a2a-morzsa -t a2a-runa -f -o cat
    else
        journalctl --user -t "a2a-$target" -f -o cat
    fi
}

usage() {
    cat <<EOF
meshctl — A2A Mesh service manager

Usage: meshctl <command> [node] [N]

Commands:
  start [node]     Start mesh node(s)
  stop [node]      Stop mesh node(s)
  restart [node]   Restart mesh node(s)
  status [node]    Show status
  log [node] [N]   Show last N log lines (default 50)
  follow [node]    Follow logs in real-time
  enable [node]    Enable auto-start on login
  disable [node]   Disable auto-start
  list             List available nodes

Nodes: morzsa, runa, all (default: all)

Examples:
  meshctl start           # Start all nodes
  meshctl status morzsa    # Check morzsa
  meshctl log runa 100    # Last 100 lines for runa
  meshctl follow          # Follow all logs
  meshctl restart morzsa  # Restart morzsa node
EOF
}

case "${1:-}" in
    start)   cmd_start "${2:-all}" ;;
    stop)    cmd_stop "${2:-all}" ;;
    restart) cmd_restart "${2:-all}" ;;
    status)  cmd_status "${2:-all}" ;;
    log)     cmd_log "${2:-all}" "${3:-50}" ;;
    follow)  cmd_follow "${2:-all}" ;;
    enable)  cmd_enable "${2:-all}" ;;
    disable) cmd_disable "${2:-all}" ;;
    list)    echo "Nodes: ${NODES[*]}" ;;
    -h|--help|help) usage ;;
    *)       error "Unknown command: $1"; usage; exit 1 ;;
esac
